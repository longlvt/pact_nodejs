{
  "name": "pact-nodejs",
  "version": "1.0.0",
  "description": "A simple Nodejs + jest project configuring contract tests with PactJS",
  "main": "src/index.js",
  "scripts": {
    "consumer": "node src/consumerService.js",
    "provider": "node src/providerService.js",
    "test:consumer": "jest __tests__/contract/consumer --runInBand --setupFiles ./__tests__/helpers/pactSetup.js --setupFilesAfterEnv=./__tests__/helpers/pactTestWrapper.js",
    "test:provider": "jest __tests__/contract/provider --runInBand --force-exit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/longlvt/pact_nodejs.git"
  },
  "keywords": [
    "nodejs",
    "contract-tests",
    "pactjs",
    "pact",
    "tutorial",
    "course",
    "tau"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@pact-foundation/pact": "^16.3.0",
    "axios": "^0.19.0",
    "babel-jest": "^30.3.0",
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "eslint": "^6.8.0",
    "express": "^4.17.1",
    "jest": "^29.0.0"
  },
  "jest": {
    "testEnvironment": "node"
  }
}
